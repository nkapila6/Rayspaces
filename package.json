{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "aerospaces",
  "title": "AeroSpaces",
  "description": "Browse and navigate Aerospace window manager spaces and their windows",
  "icon": "icon.png",
  "author": "nkapila6",
  "categories": [
    "Productivity",
    "System"
  ],
  "license": "MIT",
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "index",
      "title": "Browse Spaces",
      "subtitle": "AeroSpaces",
      "description": "View all windows grouped by Aerospace workspace",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.0",
    "shell-env": "^4.0.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
